{
  "extends": "./tsconfig",
  "compilerOptions": {
    "rootDir": "./src",
    "module": "commonjs"
  },
  "exclude": [
    "src/test/**/*",
    "node_modules/**/*",
    "dist/**/*",
    "coverage/**/*",
    "report/**/*",
    "test-results/**/*",
    "*.js",
    "*.ts",
    "scripts/**/*.js",
    "scripts/**/*.ts"
  ]
}
